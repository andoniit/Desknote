# =============================================================================
# Supabase — desknote project
# =============================================================================
# Dashboard: https://supabase.com/dashboard → Project Settings → API
#
# NEXT_PUBLIC_SUPABASE_URL — Project URL
#
# Prefer the new publishable key (starts with sb_publishable_):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
#
# Legacy JWT anon key still works if publishable is unset:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# -----------------------------------------------------------------------------
# Auth: email + 6-digit PIN (stored as Supabase “password”)
# -----------------------------------------------------------------------------
# In Supabase Dashboard → Authentication:
#
# 1) Providers → Email
#    - Turn ON “Email” (and password / email+password sign-in, depending on UI).
#    - Allow new users to sign up (disable “invite only” unless you want that).
#
# 2) Policies / Password (names vary by dashboard version)
#    - Set minimum password length to 6 so a six-digit PIN is accepted.
#    - If sign-up fails with “password does not meet requirements”, relax rules so
#      numeric-only passwords are allowed (turn off “require letters/symbols” if on).
#    - Optional: turn OFF “Leaked password protection” — it may reject common PINs.
#
# 3) Sign up / confirmations
#    - For instant sign-in with only email+PIN: disable “Confirm email” for new users
#      (or users must click the confirmation link before PIN sign-in works).
#    - If email confirmation stays ON, users see “Almost there” on /login after sign-up.
#
# 4) URL configuration
#    - Site URL (production): https://www.desknote.space
#      Local dev: http://localhost:3000
#    - Redirect URLs (include both if you use email confirmation):
#        http://localhost:3000/auth/callback
#        https://www.desknote.space/auth/callback
#      If you also use the apex host, add: https://desknote.space/auth/callback
#
# Magic link / OTP email templates are not required for this flow.
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Production: https://www.desknote.space (local dev can omit or use http://localhost:3000)
NEXT_PUBLIC_SITE_URL=https://www.desknote.space

# Optional: server-only (device API, admin); never use NEXT_PUBLIC_ for this
SUPABASE_SERVICE_ROLE_KEY=

# Provisioning only: POST /api/device/register and legacy GET/POST /api/device/notes.
# Paired desks should use per-device Bearer tokens from the register response — not this key in firmware.
DEVICE_API_KEY=change-me-to-a-long-random-string
