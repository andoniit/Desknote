# =============================================================================
# Supabase — desknote project
# =============================================================================
# Dashboard: https://supabase.com/dashboard → Project Settings → API
#
# NEXT_PUBLIC_SUPABASE_URL — Project URL
#
# Prefer the new publishable key (starts with sb_publishable_):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
#
# Legacy JWT anon key still works if publishable is unset:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: canonical site URL for magic-link redirects
NEXT_PUBLIC_SITE_URL=

# Optional: server-only (device API, admin); never use NEXT_PUBLIC_ for this
SUPABASE_SERVICE_ROLE_KEY=

# Provisioning only: POST /api/device/register and legacy GET/POST /api/device/notes.
# Paired desks should use per-device Bearer tokens from the register response — not this key in firmware.
DEVICE_API_KEY=change-me-to-a-long-random-string
